[
  {
    "bindings": {
      "ctrl-h": "workspace::ActivatePaneLeft",
      "ctrl-l": "workspace::ActivatePaneRight",
      "ctrl-k": "workspace::ActivatePaneUp",
      "ctrl-j": "workspace::ActivatePaneDown",
      "ctrl-w": "pane::ActivateNextItem",
      "ctrl-q": "pane::ActivatePreviousItem",
      "ctrl-x": "pane::CloseActiveItem",
      "ctrl-%": "pane::SplitRight",
      "ctrl-|": "pane::SplitDown"
    }
  },
  {
    "context": "vim_mode == normal && !menu",
    "bindings": {
      "space s f": "file_finder::Toggle",
      "space space": "tab_switcher::ToggleAll",
      "space w s": "project_symbols::Toggle",
      "space s g": "text_finder::Toggle",
      "space l g": "git_panel::ToggleFocus",
      "space e d": "project_panel::ToggleFocus",
      "space t h": "editor::ToggleInlayHints",
      "space c a": "editor::ToggleCodeActions",
      "space e h": "pane::SplitLeft",
      "space e j": "pane::SplitDown",
      "space e k": "pane::SplitUp",
      "space e l": "pane::SplitRight"
    }
  },
  {
    "context": "EmptyPane && !menu",
    "bindings": {
      "space s f": "file_finder::Toggle",
      "space space": "tab_switcher::ToggleAll",
      "space w s": "project_symbols::Toggle",
      "space s g": "text_finder::Toggle",
      "space l g": "git_panel::ToggleFocus",
      "space e d": "project_panel::ToggleFocus"
    }
  },
  {
    "context": "Editor && vim_mode == visual",
    "bindings": {
      "<": [
        "workspace::SendKeystrokes",
        "< g v"
      ],
      ">": [
        "workspace::SendKeystrokes",
        "> g v"
      ]
    }
  },
  {
    "context": "Editor && showing_completions",
    "bindings": {
      "ctrl-y": "editor::ConfirmCompletion"
    }
  },
  {
    "context": "Dock && !Editor && !Terminal",
    "bindings": {
      "q": "workspace::CloseActiveDock"
    }
  },
  {
    "context": "GitPanel && ChangesList && !GitBranchSelector",
    "bindings": {
      "p": "git::Pull",
      "shift-p": "git::Push",
      "c": "git::Commit",
      "shift-a": "git::Amend"
    }
  }
]
