{
    "debugger": {
        "button": false
    },
    "status_bar": {
        "line_endings_button": false,
        "show_active_file": false,
        "cursor_position_button": true,
        "active_language_button": false
    },
    "diagnostics": {
        "button": true
    },
    "search": {
        "button": false
    },
    "tab_bar": {
        "show": false
    },
    "title_bar": {
        "show_user_menu": false
    },
    "toolbar": {
        "quick_actions": false
    },
    "proxy": "",
    "minimap": {
        "show": "never"
    },
    "edit_predictions": {
        "provider": "zed"
    },
    "project_panel": {
        "button": false,
        "hide_root": true,
        "dock": "right",
        "starts_open": false
    },
    "outline_panel": {
        "button": false,
        "dock": "right"
    },
    "collaboration_panel": {
        "button": false,
        "dock": "right"
    },
    "agent": {
        "button": false,
        "dock": "right",
        "favorite_models": [],
        "model_parameters": []
    },
    "git_panel": {
        "button": false,
        "dock": "right"
    },
    "auto_install_extensions": {
        "html": true,
        "nix": true,
        "toml": true
    },
    "base_keymap": "VSCode",
    "buffer_font_size": 16,
    "file_scan_exclusions": [
        "**/__pycache__",
        "**/.DS_Store",
        "**/*.egg-info",
        "**/.mypy_cache",
        "**/.pytest_cache",
        "**/.ruff_cache",
        "**/.vscode",
        "**/.idea",
        "**/.git",
        "**/.venv",
        "**/venv",
        "**/wandb"
    ],
    "inlay_hints": {
        "enabled": true,
        "show_background": true
    },
    "languages": {
        "Python": {
            "code_actions_on_format": {
                "source.organizeImports.ruff": true
            },
            "language_servers": [
                "ty",
                "ruff"
            ],
            "formatter": {
                "language_server": {
                    "name": "ruff"
                }
            }
        }
    },
    "lsp": {
        "basedpyright": {
            "settings": {
                "basedpyright": {
                    "analysis": {
                        "autoImportCompletions": true,
                        "autoSearchPaths": true,
                        "diagnosticSeverityOverrides.reportIgnoreCommentWithoutRule": true,
                        "useLibraryCodeForTypes": true
                    },
                    "disableOrganizeImports": true,
                    "disableTaggedHints": false,
                    "typeCheckingMode": "standard"
                }
            }
        }
    },
    "soft_wrap": "editor_width",
    "ssh_connections": [
        {
            "args": [],
            "host": "workstation",
            "projects": []
        },
        {
            "args": [],
            "host": "workstation-remote",
            "projects": []
        }
    ],
    "terminal": {
        "button": false,
        "dock": "bottom",
        "blinking": "on",
        "font_size": 14,
        "line_height": {
            "custom": 1.15
        }
    },
    "theme": "rainx0r dark",
    "ui_font_size": 16,
    "vim_mode": true
}
